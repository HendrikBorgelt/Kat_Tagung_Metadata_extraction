dcat1:contactPoint a owl:ObjectProperty ;
    rdfs:label "contact point"@en ;
    rdfs:comment "Relevant contact information for the abstract"@en ;
    rdfs:domain ex:Abstract ;
    rdfs:range foaf:Person ;
    owl:inverseOf ex:isContactFor .

ex:Abstract a owl:Class ;
    rdfs:label "Abstract"@en ;
    rdfs:comment "A conference abstract submitted to Katalytikertagung"@en .

schema:Organization a owl:Class ;
    rdfs:label "Organization"@en ;
    rdfs:comment "An organization affiliated with abstract submissions"@en .

foaf:Person a owl:Class ;
    rdfs:label "Person"@en ;
    rdfs:comment "A person who contributes to abstracts"@en .

ex:hasAuthor a owl:ObjectProperty ;
    rdfs:label "has author"@en ;
    rdfs:comment "Relates an abstract to its author(s)"@en ;
    rdfs:domain ex:Abstract ;
    rdfs:range foaf:Person ;
    owl:inverseOf ex:isAuthorOf .

ex:hasAffiliation a owl:ObjectProperty ;
    rdfs:label "has affiliation"@en ;
    rdfs:comment "Relates a person to affiliated organization(s)"@en ;
    rdfs:domain foaf:Person ;
    rdfs:range schema:Organization ;
    owl:inverseOf ex:isAffiliationOf .

